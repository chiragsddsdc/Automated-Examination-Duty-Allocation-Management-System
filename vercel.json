{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "http://examduty.byethost22.com/backend/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}